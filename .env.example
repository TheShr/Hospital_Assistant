# ── Environment ──────────────────────────────────────────────────────────────
ENVIRONMENT=development

# ── Supabase ──────────────────────────────────────────────────────────────────
# Get these from: https://supabase.com → Project Settings → API
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key-here
# Get DB URL from: Project Settings → Database → Connection string (URI mode)
SUPABASE_DB_URL=postgresql://postgres:[PASSWORD]@db.your-project-id.supabase.co:5432/postgres

# ── LLM Provider ─────────────────────────────────────────────────────────────
# Choose one: "anthropic" | "groq" | "openai"
LLM_PROVIDER=anthropic

# Anthropic (Claude) — https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-3-haiku-20240307

# Groq (free, fast) — https://console.groq.com
GROQ_API_KEY=gsk_...
GROQ_MODEL=llama3-8b-8192

# OpenAI (optional)
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-3.5-turbo

# ── Embeddings ────────────────────────────────────────────────────────────────
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
EMBEDDING_DIMENSION=384

# ── Chunking ──────────────────────────────────────────────────────────────────
CHUNK_SIZE=400
CHUNK_OVERLAP=80

# ── Retrieval ─────────────────────────────────────────────────────────────────
TOP_K=5
SIMILARITY_THRESHOLD=0.3
DENSE_WEIGHT=0.7
SPARSE_WEIGHT=0.3

# ── Upload ────────────────────────────────────────────────────────────────────
MAX_FILE_SIZE_MB=20
UPLOAD_DIR=./uploads
